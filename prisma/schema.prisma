// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  name       String
  username   String   @unique
  email      String   @unique
  password   String
  bio        String?
  profileImg String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  // Lista de pessoas que este usuário está seguindo
  // Ex: user.following -> quem este user segue
  following  Follow[] @relation("FollowingRelation")

  // Lista de pessoas que estão seguindo este usuário
  // Ex: user.followers -> quem segue este user
  followers Follow[] @relation("FollowersRelation")
}

model Follow {
  userId          String
  followingUserId String
  // Relação com o usuário que está seguindo
  follower        User   @relation("FollowingRelation", fields: [userId], references: [id])

  // Relação com o usuário que está sendo seguido
  followed User @relation("FollowersRelation", fields: [followingUserId], references: [id])

  @@id([userId, followingUserId])
}
